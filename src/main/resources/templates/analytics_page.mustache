<!DOCTYPE html>
<html lang="en">
{{> fragments/html_header}}

<body>

{{> fragments/top_bar}}

<div class="container">

    <h2 class="content-center">Parking Analytics</h2>

    <!-- Busiest Hours -->
    <div class="card">
        <h3>Busiest Hours (Busy / Full Reports)</h3>
        {{#busyHours}}
        <div class="analytics-row">
            <span class="analytics-label">{{hourLabel}}</span>
            <span class="analytics-bar-wrap">
                <span class="analytics-count">{{reportCount}} reports</span>
            </span>
        </div>
        {{/busyHours}}
        {{^busyHours}}
        {{> fragments/no_content_message}}
        {{/busyHours}}
    </div>

    <!-- Most Available Lots Right Now -->
    <div class="card">
        <h3>Most Available Lots Right Now</h3>
        <table class="analytics-table">
            <thead>
                <tr>
                    <th>Lot</th>
                    <th>Status</th>
                    <th>Open Spots</th>
                    <th>Payment</th>
                    <th>Last Report</th>
                </tr>
            </thead>
            <tbody>
            {{#availableLots}}
                <tr>
                    <td>{{lotName}}</td>
                    <td><span class="badge badge-{{packedLevel}}">{{packedLevel}}</span></td>
                    <td>
                        {{#hasOpenSpots}}Yes{{/hasOpenSpots}}
                        {{^hasOpenSpots}}No{{/hasOpenSpots}}
                    </td>
                    <td>{{paymentType}}</td>
                    <td>{{lastReported}}</td>
                </tr>
            {{/availableLots}}
            {{^availableLots}}
            <tr><td colspan="5">No reports yet.</td></tr>
            {{/availableLots}}
            </tbody>
        </table>
    </div>

    <!-- Top Reporters -->
    <div class="card">
        <h3>Top Reporters</h3>
        <table class="analytics-table">
            <thead>
                <tr>
                    <th>Rank</th>
                    <th>Name</th>
                    <th>Username</th>
                    <th>Reports</th>
                </tr>
            </thead>
            <tbody>
            {{#topReporters}}
                <tr>
                    <td>{{reportCount}}</td>
                    <td>{{firstName}} {{lastName}}</td>
                    <td>@{{username}}</td>
                    <td>{{reportCount}}</td>
                </tr>
            {{/topReporters}}
            {{^topReporters}}
            <tr><td colspan="4">No data yet.</td></tr>
            {{/topReporters}}
            </tbody>
        </table>
    </div>

</div>

{{> fragments/footer}}

</body>
</html>
