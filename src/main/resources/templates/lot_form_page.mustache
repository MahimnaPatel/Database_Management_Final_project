<!DOCTYPE html>
<html lang="en">
{{> fragments/html_header}}

<body>

{{> fragments/top_bar}}

<div class="container">
    <h2 class="content-center">{{pageTitle}}</h2>

    {{> fragments/error_message}}

    <form method="post" action="{{actionUrl}}" class="form-card">
        {{#isEdit}}
        <input type="hidden" name="lotId" value="{{lot.lotId}}" />
        {{/isEdit}}

        <label for="name">Name</label>
        <input id="name" name="name" type="text" value="{{lot.name}}" required />

        <label for="address">Address</label>
        <input id="address" name="address" type="text" value="{{lot.address}}" required />

        <label for="totalCapacity">Total Capacity</label>
        <input id="totalCapacity" name="totalCapacity" type="number" value="{{lot.totalCapacity}}" min="0" required />

        <label for="paymentType">Payment Type</label>
        <select id="paymentType" name="paymentType">
            <option value="ParkMobile" {{#lot.paymentType}}{{#isParkMobile}}selected{{/isParkMobile}}{{/lot.paymentType}}>ParkMobile</option>
            <option value="Free" {{#lot.paymentType}}{{#isFree}}selected{{/isFree}}{{/lot.paymentType}}>Free</option>
            <option value="Free_After_5PM" {{#lot.paymentType}}{{#isFreeAfter5PM}}selected{{/isFreeAfter5PM}}{{/lot.paymentType}}>Free After 5 PM</option>
        </select>

        <label for="latitude">Latitude</label>
        <input id="latitude" name="latitude" type="number" step="0.000001" value="{{lot.latitude}}" />

        <label for="longitude">Longitude</label>
        <input id="longitude" name="longitude" type="number" step="0.000001" value="{{lot.longitude}}" />

        <div class="button-row">
            <button type="submit">Save</button>
            <a class="button-link" href="/lots">Cancel</a>
        </div>
    </form>
</div>

{{> fragments/footer}}

</body>
</html>
